  {
    "section": "DICOM Data Validation",
    "tasks": [
      {
        "id": "G.1",
        "task": "Validate Patient ID Match - Tag (0010,0020) - Expected: Exact match to HL7 PID-3",
        "owner": "Client"
      },
      {
        "id": "G.2",
        "task": "Validate Accession Number Match - Tag (0008,0050) - Expected: Exact match to HL7 OBR-2 or OBR-3",
        "owner": "Client"
      },
      {
        "id": "G.3",
        "task": "Validate Study Description - Tag (0008,1030) - Expected: Matches or derived from OBR-4",
        "owner": "Client"
      },
      {
        "id": "G.4",
        "task": "Validate Modality - Tag (0008,0060) - Expected: Maps to correct worklist category",
        "owner": "Client"
      },
      {
        "id": "G.5",
        "task": "Validate Institution Name - Tag (0008,0080) - Expected: Good Practice",
        "owner": "Client"
      },
      {
        "id": "G.6",
        "task": "Validate Institution Department Name - Tag (0008,1040) - Expected: Maps to correct Institution Group",
        "owner": "Client"
      },
      {
        "id": "G.7",
        "task": "Validate Station Name/AE Title - Tag (0008,1010) - Expected: Known station from expected source",
        "owner": "Client"
      },
      {
        "id": "G.8",
        "task": "Validate Study Date/Time - Tag (0008,0020/0030) - Expected: Within expected range; timezone correct",
        "owner": "Client"
      },
      {
        "id": "G.9",
        "task": "Validate Series Count - Expected: Expected series present for exam type",
        "owner": "Client"
      },
      {
        "id": "G.10",
        "task": "Validate Image Count - Expected: Complete study (not truncated)",
        "owner": "Client"
      }
    ]
  },
