{
  "name": "patient-exam-api",
  "version": "1.0.0",
  "description": "HTTP API that predicts whether previous radiology exams are relevant to a current exam",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "score": "tsx scripts/score.ts",
    "benchmark": "tsx scripts/benchmark-baselines.ts",
    "analyze": "tsx scripts/analyze-errors.ts",
    "suggest": "tsx scripts/suggest-rules.ts",
    "slice": "tsx scripts/slice-accuracy.ts"
  },
  "dependencies": {
    "express": "4.19.2",
    "tsx": "4.11.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.12.12",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
